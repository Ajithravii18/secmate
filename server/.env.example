# ─── Secmate Server Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Server
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB
# Use your MongoDB Atlas URI for production:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/secmate
MONGO_URI=mongodb://127.0.0.1:27017/secmate

# ─── Instagram API ────────────────────────────────────────────────────────────
# Step 1: Go to https://developers.facebook.com/apps/
# Step 2: Create an App → Add "Instagram Basic Display" product
# Step 3: Add @secmate_technologies as a test user
# Step 4: Generate a Long-lived User Access Token (valid 60 days)
# Step 5: Paste it below:
INSTAGRAM_ACCESS_TOKEN=

# ─── Optional: Email (for contact form) ──────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=info@secmate.in
# SMTP_PASS=your_app_password
# NOTIFY_EMAIL=info@secmate.in
